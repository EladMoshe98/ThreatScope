# Copy to .env to override defaults (all are optional — the app runs without a .env).

# --- Model ---
# Local dir with the baked weights (populated by scripts/download_model.py).
NER_MODEL_PATH=models/securebert-ner
# Max characters per inference chunk (keeps requests under the 512-token limit).
NER_MAX_CHARS_PER_CHUNK=1000

# --- Input limits ---
MAX_FILE_SIZE_MB=2

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=logs/nerf.log
LOG_DB_PATH=logs/requests.db

# --- UI (Streamlit) ---
# Where the UI reaches the API (http://api:8000 inside docker-compose).
API_URL=http://localhost:8000
